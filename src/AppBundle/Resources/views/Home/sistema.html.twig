{% extends "AppBundle::layout.html.twig" %}
{% block pageheader %}
<div class="pageheader notab">
    <h1 class="pagetitle">Configuraciones del Sistema</h1>
</div><!--pageheader-->
{% endblock %}
{% block contentwrapper %}
{% include "AppBundle::notificacion.html.twig" %}
<div id="contentwrapper" class="contentwrapper">
    <div class="two_third dashboard_left">
        <ul class="shortcuts">
            <li>
              {% if app.user.access(app.session.get('unidneg_id'),'sistema_banco_movimiento') %}
                <a href="{{ path('sistema_banco_movimiento') }}" class="banco" title="Ir a Movimientos de Banco">
                    <span class="loader">Mov. Bancarios</span>
                </a>
              {% endif %}
            </li>
            <li>
                 <a href="javascript:void(0)" class="settings" title="Check WS status">
                     <span class="loader">WsAfip Status</span>
                     <span class="loader" style="display:none"><img src={{ asset('assets/images/loaders/loader4.gif') }}></span>
                 </a>
             </li>
            <li>
                 <a href="javascript:void(0)" class="settings-single" title="Procesar una factura">
                     <span class="loader">Procesar Factura</span>
                     <span class="loader" style="display:none"><img src={{ asset('assets/images/loaders/loader4.gif') }}></span>
                 </a>
             </li>
        </ul>
        <br clear="all" />
    </div><!--two_third dashboard_left -->
</div>
{% endblock %}
{% block extra_javascripts %}
     {{ parent() }}
 <script type="text/javascript">
 jQuery(document).ready(function($) {
     // Procesar todas las facturas con CAE placeholder
     $('.settings').on('click',function(e){
         e.preventDefault();
         var url = "{{ path('ventas_factura_registrar_pendientes_afip') }}";
         var placeholderCae = '12345678901234';

         jQuery('.loader').toggle();
         var jqxhr = jQuery.post(url, { cae_placeholder: placeholderCae }, function(data){
             alert(JSON.stringify(data));
         }, 'JSON').fail(function(error) {
             alert(error.msg || 'Error en la llamada al endpoint');
         }).always(function() {
            jQuery('.loader').toggle();
         });

     });

     // Procesar una factura individual
     $('.settings-single').on('click',function(e){
         e.preventDefault();
         var facturaId = prompt('Ingresa el ID de la factura a procesar:', '');

         if (facturaId === null || facturaId.trim() === '') {
             return; // Usuario canceló o ingresó vacío
         }

         if (isNaN(facturaId)) {
             alert('El ID debe ser un número válido');
             return;
         }

         var url = "{{ path('ventas_factura_registrar_pendientes_afip') }}";
         var loaders = $(this).find('.loader');

         loaders.toggle();

         jQuery.post(url, { factura_ids: [facturaId] }, function(data){
             if (data.results && data.results.length > 0) {
                 var result = data.results[0];
                 if (result.status === 'OK') {
                     alert('✓ Factura ' + result.id + ' procesada exitosamente\n' +
                           'CAE: ' + result.cae + '\n' +
                           'Nro Comprobante: ' + result.nroComprobante + '\n' +
                           'Vto CAE: ' + result.caeVto);
                 } else {
                     alert('✗ Error procesando factura ' + result.id + ':\n' + result.message);
                 }
             }
         }, 'JSON').fail(function(error) {
             alert('Error en la llamada: ' + (error.msg || error.statusText || 'Error desconocido'));
         }).always(function() {
            loaders.toggle();
         });
     });
 });
 </script>
 {% endblock %}